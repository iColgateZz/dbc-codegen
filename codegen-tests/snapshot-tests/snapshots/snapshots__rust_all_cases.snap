                Msg::FloatPayload32(FloatPayload32Msg::try_from_frame(frame)?)
            }
            FloatPayload64Msg::ID => {
                Msg::FloatPayload64(FloatPayload64Msg::try_from_frame(frame)?)
            }
            MuxedTelemetryMsg::ID => {
                Msg::MuxedTelemetry(MuxedTelemetryMsg::try_from_frame(frame)?)
            }
            EmptyZeroDlcMsg::ID => {
                Msg::EmptyZeroDlc(EmptyZeroDlcMsg::try_from_frame(frame)?)
            }
            ExtendedClassicMsg::ID => {
                Msg::ExtendedClassic(ExtendedClassicMsg::try_from_frame(frame)?)
            }
            ExtendedCanFdMsg::ID => {
                Msg::ExtendedCanFd(ExtendedCanFdMsg::try_from_frame(frame)?)
            }
            VariableLengthMsg::ID => {
                Msg::VariableLength(VariableLengthMsg::try_from_frame(frame)?)
            }
            J1939SnapshotMsg::ID => {
                Msg::J1939Snapshot(J1939SnapshotMsg::try_from_frame(frame)?)
            }
            _ => return Err(CanError::UnknownFrameId),
        };
        Ok(result)
    }
