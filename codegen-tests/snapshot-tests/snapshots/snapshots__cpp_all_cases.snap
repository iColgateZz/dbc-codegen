class MuxedTelemetryMsgMux0 {
  public:
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<MuxedTelemetryMsgMux0, CanError> create(
            float mux0_distance,
            uint8_t mux0_state
        ) noexcept {
    MuxedTelemetryMsgMux0 msg{};
    if (auto r = msg.set_mux0_distance(mux0_distance); !r) return std::unexpected(r.error());
    if (auto r = msg.set_mux0_state(mux0_state); !r) return std::unexpected(r.error());
    return msg;
  };
  
  /**
   * mux0_distance
   * - Min: 0
   * - Max: 6553.5
   * - Unit: m
   * - Receivers: NODE_B
   * - Start bit: 16
   * - Size: 16 bits
   * - Factor: 0.1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] float mux0_distance() const noexcept {
    const uint16_t raw_mux0_distance = detail::extract_le<uint16_t>(data_.data(), 16, 32);
    return static_cast<float>(raw_mux0_distance) * 0.1f + 0.0f;
  };
  
  /**
   * mux0_state
   * - Min: 0
   * - Max: 255
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 32
   * - Size: 8 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] uint8_t mux0_state() const noexcept {
    const uint8_t raw_mux0_state = detail::extract_le<uint8_t>(data_.data(), 32, 40);
    return detail::saturating_add<uint8_t>(detail::saturating_mul<uint8_t>(static_cast<uint8_t>(raw_mux0_state), static_cast<uint8_t>(1)), static_cast<uint8_t>(0));
  };
  
  std::expected<void, CanError> set_mux0_distance(float mux0_distance) noexcept {
    if (mux0_distance < 0.0f || mux0_distance > 6553.5f) return std::unexpected(CanError::ValueOutOfRange);
    detail::insert_le<uint16_t>(data_.data(), 16, 32, static_cast<uint16_t>((mux0_distance - 0.0f) / 0.1f));
    return {};
  };
  
  std::expected<void, CanError> set_mux0_state(uint8_t mux0_state) noexcept {
    if (mux0_state < 0 || mux0_state > 255) return std::unexpected(CanError::ValueOutOfRange);
    const auto mux0_state_shifted = detail::checked_sub<uint8_t>(mux0_state, static_cast<uint8_t>(0));
    if (!mux0_state_shifted) return std::unexpected(mux0_state_shifted.error());
    const auto mux0_state_raw = detail::checked_div<uint8_t>(*mux0_state_shifted, static_cast<uint8_t>(1));
    if (!mux0_state_raw) return std::unexpected(mux0_state_raw.error());
    detail::insert_le<uint8_t>(data_.data(), 32, 40, static_cast<uint8_t>(*mux0_state_raw));
    return {};
  };
  
  [[nodiscard]] std::array<uint8_t, LEN> encode() const noexcept { return data_; }
  
  private:
  friend class MuxedTelemetryMsg;
  std::array<uint8_t, LEN> data_{};
};

