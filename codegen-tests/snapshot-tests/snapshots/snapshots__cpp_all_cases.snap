static_assert(GeneratedCanMessage<VariableLengthMsg>);

/**
 * J1939Snapshot
 * - ID: Extended 355729921 (0x15340201)
 * - Size: 8 bytes
 * - Transmitter: NODE_A
 */
class J1939SnapshotMsg {
  public:
  static constexpr CanId ID = CanId::extended(355729921);
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<J1939SnapshotMsg, CanError> create(
            int8_t j1939_signal
        ) noexcept {
    J1939SnapshotMsg msg{};
    if (auto r = msg.set_j1939_signal(j1939_signal); !r) return std::unexpected(r.error());
    return msg;
  };
  
  [[nodiscard]] static std::expected<J1939SnapshotMsg, CanError> try_from_frame(CanId id, std::span<const uint8_t> frame) noexcept {
    if (frame.size() < LEN) return std::unexpected(CanError::InvalidPayloadSize);
    if (id != ID) return std::unexpected(CanError::InvalidFrameId);
    J1939SnapshotMsg msg{};
    std::memcpy(msg.data_.data(), frame.data(), LEN);
    return msg;
  };
  
  /**
   * j1939_signal
   * - Min: -128
   * - Max: 127
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 0
   * - Size: 8 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: signed
   */
  [[nodiscard]] int8_t j1939_signal() const noexcept {
    const int8_t raw_j1939_signal = detail::extract_le<int8_t>(data_.data(), 0, 8);
    return detail::saturating_add<int8_t>(detail::saturating_mul<int8_t>(static_cast<int8_t>(raw_j1939_signal), static_cast<int8_t>(1)), static_cast<int8_t>(0));
  };
  
  std::expected<void, CanError> set_j1939_signal(int8_t j1939_signal) noexcept {
    if (j1939_signal < -128 || j1939_signal > 127) return std::unexpected(CanError::ValueOutOfRange);
    const auto j1939_signal_shifted = detail::checked_sub<int8_t>(j1939_signal, static_cast<int8_t>(0));
    if (!j1939_signal_shifted) return std::unexpected(j1939_signal_shifted.error());
    const auto j1939_signal_raw = detail::checked_div<int8_t>(*j1939_signal_shifted, static_cast<int8_t>(1));
    if (!j1939_signal_raw) return std::unexpected(j1939_signal_raw.error());
    detail::insert_le<int8_t>(data_.data(), 0, 8, static_cast<int8_t>(*j1939_signal_raw));
    return {};
  };
  
  [[nodiscard]] std::array<uint8_t, LEN> encode() const noexcept { return data_; }
  
  private:
  std::array<uint8_t, LEN> data_{};
};
static_assert(GeneratedCanMessage<J1939SnapshotMsg>);

using CanMsg = std::variant<PackedStatusMsg, MotorolaAnalogMsg, FloatPayload32Msg, FloatPayload64Msg, MuxedTelemetryMsg, EmptyZeroDlcMsg, ExtendedClassicMsg, ExtendedCanFdMsg, VariableLengthMsg, J1939SnapshotMsg>;

[[nodiscard]]
inline std::expected<CanMsg, CanError>
parse_can(CanId id, std::span<const uint8_t> frame) noexcept {
  switch (id.dispatch_key()) {
    case PackedStatusMsg::ID.dispatch_key():
     {
      auto r = PackedStatusMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case MotorolaAnalogMsg::ID.dispatch_key():
     {
      auto r = MotorolaAnalogMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case FloatPayload32Msg::ID.dispatch_key():
     {
      auto r = FloatPayload32Msg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case FloatPayload64Msg::ID.dispatch_key():
     {
      auto r = FloatPayload64Msg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case MuxedTelemetryMsg::ID.dispatch_key():
     {
      auto r = MuxedTelemetryMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case EmptyZeroDlcMsg::ID.dispatch_key():
     {
      auto r = EmptyZeroDlcMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case ExtendedClassicMsg::ID.dispatch_key():
     {
      auto r = ExtendedClassicMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case ExtendedCanFdMsg::ID.dispatch_key():
     {
      auto r = ExtendedCanFdMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case VariableLengthMsg::ID.dispatch_key():
     {
      auto r = VariableLengthMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    case J1939SnapshotMsg::ID.dispatch_key():
     {
      auto r = J1939SnapshotMsg::try_from_frame(id, frame);
      if (!r) return std::unexpected(r.error());
      return CanMsg{std::move(*r)};
    };
    default: return std::unexpected(CanError::UnknownFrameId);
  };
};
