/**
 * PackedStatus
 * - ID: Standard 100 (0x64)
 * - Size: 8 bytes
 * - Transmitter: NODE_A
 * 
 * Packed little-endian status values
 */
class PackedStatusMsg {
  public:
  static constexpr CanId ID = CanId::standard(100);
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<PackedStatusMsg, CanError> create(
            bool enabled,
            ModeEnum mode,
            StateAEnum state_a,
            int16_t signed_temp,
            float scaled_speed,
            uint8_t type,
            uint8_t unspecified_range
        ) noexcept {
    PackedStatusMsg msg{};
    if (auto r = msg.set_enabled(enabled); !r) return std::unexpected(r.error());
    if (auto r = msg.set_mode(mode); !r) return std::unexpected(r.error());
    if (auto r = msg.set_state_a(state_a); !r) return std::unexpected(r.error());
    if (auto r = msg.set_signed_temp(signed_temp); !r) return std::unexpected(r.error());
    if (auto r = msg.set_scaled_speed(scaled_speed); !r) return std::unexpected(r.error());
    if (auto r = msg.set_type(type); !r) return std::unexpected(r.error());
    if (auto r = msg.set_unspecified_range(unspecified_range); !r) return std::unexpected(r.error());
    return msg;
  };
  
  [[nodiscard]] static std::expected<PackedStatusMsg, CanError> try_from_frame(CanId id, std::span<const uint8_t> frame) noexcept {
    if (frame.size() < LEN) return std::unexpected(CanError::InvalidPayloadSize);
    if (id != ID) return std::unexpected(CanError::InvalidFrameId);
    PackedStatusMsg msg{};
    std::memcpy(msg.data_.data(), frame.data(), LEN);
    return msg;
  };
  
  /**
   * enabled
   * - Min: 0
   * - Max: 1
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 0
   * - Size: 1 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] bool enabled() const noexcept {
    const uint8_t raw_enabled = detail::extract_le<uint8_t>(data_.data(), 0, 1);
    return raw_enabled != 0;
  };
  
  /**
   * mode
   * - Min: 0
   * - Max: 7
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 1
   * - Size: 3 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] ModeEnum mode() const noexcept {
    const uint8_t raw_mode = detail::extract_le<uint8_t>(data_.data(), 1, 4);
    return mode_enum_from_raw(raw_mode);
  };
  
  /**
   * state_a
   * - Min: 0
   * - Max: 3
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 4
   * - Size: 2 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] StateAEnum state_a() const noexcept {
    const uint8_t raw_state_a = detail::extract_le<uint8_t>(data_.data(), 4, 6);
    return state_a_enum_from_raw(raw_state_a);
  };
  
  /**
   * signed_temp
   * - Min: -168
   * - Max: 87
   * - Unit: degC
   * - Receivers: NODE_B
   * - Start bit: 8
   * - Size: 8 bits
   * - Factor: 1
   * - Offset: -40
   * - Byte order: LittleEndian
   * - Type: signed
   */
  [[nodiscard]] int16_t signed_temp() const noexcept {
    const int8_t raw_signed_temp = detail::extract_le<int8_t>(data_.data(), 8, 16);
    return detail::saturating_add<int16_t>(detail::saturating_mul<int16_t>(static_cast<int16_t>(raw_signed_temp), static_cast<int16_t>(1)), static_cast<int16_t>(-40));
  };
  
  /**
   * scaled_speed
   * - Min: 0
   * - Max: 655.35
   * - Unit: kph
   * - Receivers: NODE_B
   * - Start bit: 16
   * - Size: 16 bits
   * - Factor: 0.01
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   * 
   * Scaled speed signal used by snapshot testing
   */
  [[nodiscard]] float scaled_speed() const noexcept {
    const uint16_t raw_scaled_speed = detail::extract_le<uint16_t>(data_.data(), 16, 32);
    return static_cast<float>(raw_scaled_speed) * 0.01f + 0.0f;
  };
  
  /**
   * type
   * - Min: 0
   * - Max: 255
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 32
   * - Size: 8 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] uint8_t type() const noexcept {
    const uint8_t raw_type = detail::extract_le<uint8_t>(data_.data(), 32, 40);
    return detail::saturating_add<uint8_t>(detail::saturating_mul<uint8_t>(static_cast<uint8_t>(raw_type), static_cast<uint8_t>(1)), static_cast<uint8_t>(0));
  };
  
  /**
   * unspecified_range
   * - Min: 0
   * - Max: 0
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 40
   * - Size: 8 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] uint8_t unspecified_range() const noexcept {
    const uint8_t raw_unspecified_range = detail::extract_le<uint8_t>(data_.data(), 40, 48);
    return detail::saturating_add<uint8_t>(detail::saturating_mul<uint8_t>(static_cast<uint8_t>(raw_unspecified_range), static_cast<uint8_t>(1)), static_cast<uint8_t>(0));
  };
  
  std::expected<void, CanError> set_enabled(bool enabled) noexcept {
    detail::insert_le<uint8_t>(data_.data(), 0, 1, static_cast<uint8_t>(enabled));
    return {};
  };
  
  std::expected<void, CanError> set_mode(ModeEnum mode) noexcept {
    detail::insert_le<uint8_t>(data_.data(), 1, 4, static_cast<uint8_t>(mode));
    return {};
  };
  
  std::expected<void, CanError> set_state_a(StateAEnum state_a) noexcept {
    detail::insert_le<uint8_t>(data_.data(), 4, 6, static_cast<uint8_t>(state_a));
    return {};
  };
  
  std::expected<void, CanError> set_signed_temp(int16_t signed_temp) noexcept {
    if (signed_temp < -168 || signed_temp > 87) return std::unexpected(CanError::ValueOutOfRange);
    const auto signed_temp_shifted = detail::checked_sub<int16_t>(signed_temp, static_cast<int16_t>(-40));
    if (!signed_temp_shifted) return std::unexpected(signed_temp_shifted.error());
    const auto signed_temp_raw = detail::checked_div<int16_t>(*signed_temp_shifted, static_cast<int16_t>(1));
    if (!signed_temp_raw) return std::unexpected(signed_temp_raw.error());
    detail::insert_le<int8_t>(data_.data(), 8, 16, static_cast<int8_t>(*signed_temp_raw));
    return {};
  };
  
  std::expected<void, CanError> set_scaled_speed(float scaled_speed) noexcept {
    if (scaled_speed < 0.0f || scaled_speed > 655.35f) return std::unexpected(CanError::ValueOutOfRange);
    detail::insert_le<uint16_t>(data_.data(), 16, 32, static_cast<uint16_t>((scaled_speed - 0.0f) / 0.01f));
    return {};
  };
  
  std::expected<void, CanError> set_type(uint8_t type) noexcept {
    if (type < 0 || type > 255) return std::unexpected(CanError::ValueOutOfRange);
    const auto type_shifted = detail::checked_sub<uint8_t>(type, static_cast<uint8_t>(0));
    if (!type_shifted) return std::unexpected(type_shifted.error());
    const auto type_raw = detail::checked_div<uint8_t>(*type_shifted, static_cast<uint8_t>(1));
    if (!type_raw) return std::unexpected(type_raw.error());
    detail::insert_le<uint8_t>(data_.data(), 32, 40, static_cast<uint8_t>(*type_raw));
    return {};
  };
  
  std::expected<void, CanError> set_unspecified_range(uint8_t unspecified_range) noexcept {
    if (unspecified_range < 0 || unspecified_range > 0) return std::unexpected(CanError::ValueOutOfRange);
    const auto unspecified_range_shifted = detail::checked_sub<uint8_t>(unspecified_range, static_cast<uint8_t>(0));
    if (!unspecified_range_shifted) return std::unexpected(unspecified_range_shifted.error());
    const auto unspecified_range_raw = detail::checked_div<uint8_t>(*unspecified_range_shifted, static_cast<uint8_t>(1));
    if (!unspecified_range_raw) return std::unexpected(unspecified_range_raw.error());
    detail::insert_le<uint8_t>(data_.data(), 40, 48, static_cast<uint8_t>(*unspecified_range_raw));
    return {};
  };
  
  [[nodiscard]] std::array<uint8_t, LEN> encode() const noexcept { return data_; }
  
  private:
  std::array<uint8_t, LEN> data_{};
};
static_assert(GeneratedCanMessage<PackedStatusMsg>);

/**
 * MotorolaAnalog
 * - ID: Standard 101 (0x65)
 * - Size: 8 bytes
 * - Transmitter: NODE_A
 * 
 * Motorola signal layout with comments
 */
class MotorolaAnalogMsg {
  public:
  static constexpr CanId ID = CanId::standard(101);
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<MotorolaAnalogMsg, CanError> create(
            float motorola_temp,
            float motorola_radius,
            MotorolaEnableEnum motorola_enable,
            float motorola_float32
        ) noexcept {
    MotorolaAnalogMsg msg{};
    if (auto r = msg.set_motorola_temp(motorola_temp); !r) return std::unexpected(r.error());
    if (auto r = msg.set_motorola_radius(motorola_radius); !r) return std::unexpected(r.error());
    if (auto r = msg.set_motorola_enable(motorola_enable); !r) return std::unexpected(r.error());
    if (auto r = msg.set_motorola_float32(motorola_float32); !r) return std::unexpected(r.error());
    return msg;
  };
  
  [[nodiscard]] static std::expected<MotorolaAnalogMsg, CanError> try_from_frame(CanId id, std::span<const uint8_t> frame) noexcept {
    if (frame.size() < LEN) return std::unexpected(CanError::InvalidPayloadSize);
    if (id != ID) return std::unexpected(CanError::InvalidFrameId);
    MotorolaAnalogMsg msg{};
    std::memcpy(msg.data_.data(), frame.data(), LEN);
    return msg;
  };
  
  /**
   * motorola_temp
   * - Min: 229.52
   * - Max: 270.47
   * - Unit: degK
   * - Receivers: NODE_B, NODE_C
   * - Start bit: 7
   * - Size: 12 bits
   * - Factor: 0.01
   * - Offset: 250
   * - Byte order: BigEndian
   * - Type: signed
   * 
   * Signed big-endian scaled temperature
   */
  [[nodiscard]] float motorola_temp() const noexcept {
    const int16_t raw_motorola_temp = detail::extract_be<int16_t>(data_.data(), 7, 19);
    return static_cast<float>(raw_motorola_temp) * 0.01f + 250.0f;
  };
  
  /**
   * motorola_radius
   * - Min: 0
   * - Max: 5
   * - Unit: m
   * - Receivers: NODE_B
   * - Start bit: 1
   * - Size: 6 bits
   * - Factor: 0.1
   * - Offset: 0
   * - Byte order: BigEndian
   * - Type: unsigned
   */
  [[nodiscard]] float motorola_radius() const noexcept {
    const uint8_t raw_motorola_radius = detail::extract_be<uint8_t>(data_.data(), 1, 7);
    return static_cast<float>(raw_motorola_radius) * 0.1f + 0.0f;
  };
  
  /**
   * motorola_enable
   * - Min: 0
   * - Max: 1
   * - Unit: -
   * - Receivers: NODE_B
   * - Start bit: 0
   * - Size: 1 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: BigEndian
   * - Type: unsigned
   */
  [[nodiscard]] MotorolaEnableEnum motorola_enable() const noexcept {
    const uint8_t raw_motorola_enable = detail::extract_be<uint8_t>(data_.data(), 0, 1);
    return motorola_enable_enum_from_raw(raw_motorola_enable);
  };
  
  /**
   * motorola_float32
   * - Min: 0
   * - Max: 5
   * - Unit: m
   * - Receivers: NODE_C
   * - Start bit: 31
   * - Size: 32 bits
   * - Factor: 0.1
   * - Offset: 0
   * - Byte order: BigEndian
   * - Type: signed
   */
  [[nodiscard]] float motorola_float32() const noexcept {
    const uint32_t motorola_float32_bits = detail::extract_be<uint32_t>(data_.data(), 31, 63);
    float motorola_float32_raw; std::memcpy(&motorola_float32_raw, &motorola_float32_bits, sizeof(float));
    return motorola_float32_raw * 0.1f + 0.0f;
  };
  
  std::expected<void, CanError> set_motorola_temp(float motorola_temp) noexcept {
    if (motorola_temp < 229.52f || motorola_temp > 270.47f) return std::unexpected(CanError::ValueOutOfRange);
    detail::insert_be<int16_t>(data_.data(), 7, 19, static_cast<int16_t>((motorola_temp - 250.0f) / 0.01f));
    return {};
  };
  
  std::expected<void, CanError> set_motorola_radius(float motorola_radius) noexcept {
    if (motorola_radius < 0.0f || motorola_radius > 5.0f) return std::unexpected(CanError::ValueOutOfRange);
    detail::insert_be<uint8_t>(data_.data(), 1, 7, static_cast<uint8_t>((motorola_radius - 0.0f) / 0.1f));
    return {};
  };
  
  std::expected<void, CanError> set_motorola_enable(MotorolaEnableEnum motorola_enable) noexcept {
    detail::insert_be<uint8_t>(data_.data(), 0, 1, static_cast<uint8_t>(motorola_enable));
    return {};
  };
  
  std::expected<void, CanError> set_motorola_float32(float motorola_float32) noexcept {
    if (motorola_float32 < 0.0f || motorola_float32 > 5.0f) return std::unexpected(CanError::ValueOutOfRange);
    const float motorola_float32_raw = (motorola_float32 - 0.0f) / 0.1f;
    uint32_t motorola_float32_bits; std::memcpy(&motorola_float32_bits, &motorola_float32_raw, sizeof(uint32_t));
    detail::insert_be<uint32_t>(data_.data(), 31, 63, motorola_float32_bits);
    return {};
  };
  
  [[nodiscard]] std::array<uint8_t, LEN> encode() const noexcept { return data_; }
  
  private:
  std::array<uint8_t, LEN> data_{};
};
static_assert(GeneratedCanMessage<MotorolaAnalogMsg>);

/**
 * FloatPayload32
 * - ID: Standard 102 (0x66)
 * - Size: 8 bytes
 * - Transmitter: NODE_A
 */
class FloatPayload32Msg {
  public:
  static constexpr CanId ID = CanId::standard(102);
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<FloatPayload32Msg, CanError> create(
            float float32_a,
            float float32_b
        ) noexcept {
    FloatPayload32Msg msg{};
    if (auto r = msg.set_float32_a(float32_a); !r) return std::unexpected(r.error());
    if (auto r = msg.set_float32_b(float32_b); !r) return std::unexpected(r.error());
    return msg;
  };
  
