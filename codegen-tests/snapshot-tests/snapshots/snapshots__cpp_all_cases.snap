using MuxedTelemetryMsgMux = std::variant<MuxedTelemetryMsgMux0, MuxedTelemetryMsgMux1>;

/**
 * MuxedTelemetry
 * - ID: Standard 104 (0x68)
 * - Size: 8 bytes
 * - Transmitter: NODE_A
 */
class MuxedTelemetryMsg {
  public:
  static constexpr CanId ID = CanId::standard(104);
  static constexpr std::size_t LEN{8};
  
  [[nodiscard]] static std::expected<MuxedTelemetryMsg, CanError> create(uint16_t common_count, MuxedTelemetryMsgMux mux) noexcept {
    MuxedTelemetryMsg msg{};
    if (auto r = msg.set_common_count(common_count); !r) return std::unexpected(r.error());
    std::visit([&msg](const auto& v) {
      using T = std::decay_t<decltype(v)>;
      if constexpr (std::is_same_v<T, MuxedTelemetryMsgMux0>) {
        msg.set_mux_0(v);
      };
      if constexpr (std::is_same_v<T, MuxedTelemetryMsgMux1>) {
        msg.set_mux_1(v);
      };
    }, mux);
    
    return msg;
  };
  
  [[nodiscard]] static std::expected<MuxedTelemetryMsg, CanError> try_from_frame(CanId id, std::span<const uint8_t> frame) noexcept {
    if (frame.size() < LEN) return std::unexpected(CanError::InvalidPayloadSize);
    if (id != ID) return std::unexpected(CanError::InvalidFrameId);
    MuxedTelemetryMsg msg{};
    std::memcpy(msg.data_.data(), frame.data(), LEN);
    return msg;
  };
  
  /**
   * common_count
   * - Min: 0
   * - Max: 4095
   * - Unit: 
   * - Receivers: NODE_B
   * - Start bit: 4
   * - Size: 12 bits
   * - Factor: 1
   * - Offset: 0
   * - Byte order: LittleEndian
   * - Type: unsigned
   */
  [[nodiscard]] uint16_t common_count() const noexcept {
    const uint16_t raw_common_count = detail::extract_le<uint16_t>(data_.data(), 4, 16);
    return detail::saturating_add<uint16_t>(detail::saturating_mul<uint16_t>(static_cast<uint16_t>(raw_common_count), static_cast<uint16_t>(1)), static_cast<uint16_t>(0));
  };
  
  std::expected<void, CanError> set_common_count(uint16_t common_count) noexcept {
    if (common_count < 0 || common_count > 4095) return std::unexpected(CanError::ValueOutOfRange);
    const auto common_count_shifted = detail::checked_sub<uint16_t>(common_count, static_cast<uint16_t>(0));
    if (!common_count_shifted) return std::unexpected(common_count_shifted.error());
    const auto common_count_raw = detail::checked_div<uint16_t>(*common_count_shifted, static_cast<uint16_t>(1));
    if (!common_count_raw) return std::unexpected(common_count_raw.error());
    detail::insert_le<uint16_t>(data_.data(), 4, 16, static_cast<uint16_t>(*common_count_raw));
    return {};
  };
  
  [[nodiscard]] std::expected<MuxedTelemetryMsgMux, CanError> mux() const noexcept {
    const uint8_t mux_raw = detail::extract_le<uint8_t>(data_.data(), 0, 4);
    switch (mux_raw) {
      case 0: {
        MuxedTelemetryMsgMux0 inner{};
        std::memcpy(inner.data_.data(), data_.data(), LEN);
        return inner;
      };
      case 1: {
        MuxedTelemetryMsgMux1 inner{};
        std::memcpy(inner.data_.data(), data_.data(), LEN);
        return inner;
      };
      default: return std::unexpected(CanError::UnknownMuxValue);
    };
  };
  
  void set_mux_0(const MuxedTelemetryMsgMux0& value) noexcept {
    detail::copy_le(data_.data(), value.data_.data(), 16, 32);
    detail::copy_le(data_.data(), value.data_.data(), 32, 40);
    detail::insert_le<uint8_t>(data_.data(), 0, 4, static_cast<uint8_t>(0));
  };
  void set_mux_1(const MuxedTelemetryMsgMux1& value) noexcept {
    detail::copy_le(data_.data(), value.data_.data(), 16, 32);
    detail::copy_le(data_.data(), value.data_.data(), 32, 40);
    detail::insert_le<uint8_t>(data_.data(), 0, 4, static_cast<uint8_t>(1));
  };
  
  [[nodiscard]] std::array<uint8_t, LEN> encode() const noexcept { return data_; }
  
  private:
  std::array<uint8_t, LEN> data_{};
};
static_assert(GeneratedCanMessage<MuxedTelemetryMsg>);

