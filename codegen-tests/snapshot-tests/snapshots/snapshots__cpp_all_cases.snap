  std::expected<void, CanError> set_var_a(uint16_t var_a) noexcept {
    if (var_a < 0 || var_a > 32767) return std::unexpected(CanError::ValueOutOfRange);
    const auto var_a_shifted = detail::checked_sub<uint16_t>(var_a, static_cast<uint16_t>(0));
